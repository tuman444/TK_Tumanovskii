<Window x:Class="TK.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TK"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <Label Content="Число 1:"/>
            <TextBox x:Name="TxtNum1" Margin="0,0,0,5"/>

            <Label Content="Число 2:"/>
            <TextBox x:Name="TxtNum2" Margin="0,0,0,5"/>

            <Label Content="Число 3:"/>
            <TextBox x:Name="TxtNum3" Margin="0,0,0,10"/>

            <GroupBox Header="Выбор операции" Margin="0,0,0,10">
                <StackPanel>
                    <RadioButton x:Name="RbMax" Content="максимум" IsChecked="True"/>
                    <RadioButton x:Name="RbMin" Content="минимум"/>
                </StackPanel>
            </GroupBox>

            <Button Content="Вычислить" Click="BtnCalculate_Click" Width="100" HorizontalAlignment="Right"/>

            <TextBlock x:Name="TxtResult" Text="Результат = " Margin="0,10,0,0" FontSize="14" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
